\@writefile{lof}{\contentsline {figure}{\numberline {4.2}{\ignorespaces Overview of the four-stage precise-alignment pipeline. A live point cloud is acquired from the physical vine (\emph  {Stage~1}), passed through a preprocessing pipeline (\emph  {Stage~2}), registered against the SfM target cloud derived from the 3DGS model using GICP (\emph  {Stage~3}), and the recovered rigid transform is applied to update the robot pose estimate (\emph  {Stage~4}), which is consumed by the arm path planner.}}{61}{}\protected@file@percent }
\newlabel{fig:pa-approach-overview}{{4.2}{61}{}{figure.4.2}{}}
\newlabel{fig:pa-approach-overview@cref}{{[figure][2][4]4.2}{[1][61][]61}{}{}{}}
